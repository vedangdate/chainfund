# --- Contract deployment (root Hardhat project) ---
# Any Sepolia JSON-RPC endpoint. Free options: Alchemy, Infura, or the public node.
SEPOLIA_RPC_URL=https://rpc.sepolia.org
# Private key (no 0x prefix) of a TESTNET-ONLY wallet. Generate with: npm run newwallet
DEPLOYER_PRIVATE_KEY=
# Optional — for `hardhat verify` on Etherscan.
ETHERSCAN_API_KEY=

# --- Backend indexer (backend/) ---
# Same RPC works; an HTTPS endpoint is fine for polling.
RPC_URL=https://rpc.sepolia.org
PORT=8787
